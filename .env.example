NEXT_PUBLIC_SUPABASE_URL=
# Server-only: copy the "service_role" secret from Supabase → Project Settings → API.
# Do NOT use the anon / publishable / "sb_publishable_..." key here — this app needs service_role for API routes.
SUPABASE_SERVICE_ROLE_KEY=
FAMILY_SESSION_SECRET=change-this-to-a-long-random-string

# Optional: plain family password. If set, login uses this instead of app_settings in Supabase.
# FAMILY_PASSCODE=your-family-word

